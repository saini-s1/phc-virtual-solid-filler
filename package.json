{
  "name": "phc-modeling-suite",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:full": "concurrently -n vite,api -c blue,green \"npm:dev\" \"npm:server\"",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.0",
    "@react-three/fiber": "^8.18.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "framer-motion": "^11.18.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}

# Copy this file to `.env` for local development (never commit `.env`).
# In Azure App Service, set these as Application Settings (Configuration blade)
# instead of a checked-in file — see docs/DEPLOYMENT.md.

# Port the Express server listens on. Azure App Service sets this automatically
# in production; only needed locally if you want something other than 8080.
PORT=8080

# --- Custom ingredient library persistence (server/store.js) -----------------
# When set, the server persists "Save to library" ingredients to Azure Table
# Storage. When unset, it falls back to a local JSON file (server/data/, gitignored)
# so the feature still works with zero cloud setup during development.
#
# Get this from: Azure Portal → Storage Account → Access keys → Connection string.
# Treat this as a secret (grants full access to the storage account).
AZURE_STORAGE_CONNECTION_STRING=

# Table name for saved ingredients. Optional, defaults to "CustomIngredients".
AZURE_STORAGE_TABLE_NAME=CustomIngredients
